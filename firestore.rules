rules_version = '2';

// Regras de segurança do Firestore para o Palace Lounge.
// Cole isto em: Firebase Console > Firestore Database > Regras > Publicar.
service cloud.firestore {
  match /databases/{database}/documents {

    // Conteúdo público do site: qualquer pessoa lê; só administradores autenticados escrevem.
    match /config/{doc}   { allow read: if true; allow write: if request.auth != null; }
    match /menu/{doc}     { allow read: if true; allow write: if request.auth != null; }
    match /gallery/{doc}  { allow read: if true; allow write: if request.auth != null; }

    // Reservas: qualquer visitante pode criar um pedido;
    // apenas administradores autenticados podem ler/editar.
    match /reservations/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
